# Public URLs used by WhatsApp checkout links and browser clients
PUBLIC_ADMIN_BASE_URL=https://app.seu-dominio.com
PUBLIC_WEB_BASE_URL=https://app.seu-dominio.com
NGROK_PUBLIC_URL=

# pgAdmin local access
PGADMIN_DEFAULT_EMAIL=admin@clickgarcom.dev
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# Repository layout defaults used by Docker Compose during the migration
CORE_BACKEND_DIR=./platform/core-backend
TENANT_ADMIN_API_DIR=./apps/tenant-admin/api
TENANT_ADMIN_WEB_DIR=./apps/tenant-admin/web
SUPER_ADMIN_WEB_DIR=./apps/super-admin/web

# Internal service routing used by go-api public proxy
PUBLIC_WEB_INTERNAL_BASE_URL=http://web-admin:3004
PUBLIC_ADMIN_INTERNAL_BASE_URL=http://node-admin:3002

# Node Admin runtime
ADMIN_WEB_ENABLED=false

# Web Admin runtime config served to the browser
ADMIN_API_BASE_URL=https://app.seu-dominio.com/admin/api
ADMIN_PUBLIC_API_BASE_URL=https://app.seu-dominio.com/admin/api/public/tables
KDS_WS_URL=wss://app.seu-dominio.com/ws/kds
